# ── CompanyCard connector server ───────────────────────────────
# Copy to ".env" and fill in. Run with: npm start  (or: node --env-file=.env server.js)

PORT=4000
BASE_URL=http://localhost:4000
# Where your static site is served from (the page that opens the OAuth popup)
FRONTEND_ORIGIN=http://localhost:5500
SESSION_SECRET=change-me-to-a-long-random-string
# In production over HTTPS set these for cross-site cookies:
COOKIE_SECURE=false      # true in production
COOKIE_SAMESITE=lax      # none in production (requires COOKIE_SECURE=true)

# ── Google Workspace ───────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
# Enable the "Admin SDK API". Authorised redirect URI:
#   {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft 365 / Entra ID ───────────────────────────────────
# Azure Portal → App registrations → your app.
# API permissions (Microsoft Graph, delegated): User.Read.All  (grant admin consent)
# Redirect URI (Web): {BASE_URL}/auth/microsoft/callback
MS_TENANT=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
